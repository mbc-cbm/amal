#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Firebase / secrets — NEVER commit these
ios/Runner/GoogleService-Info.plist
android/app/google-services.json
scripts/service-account-key.json
**/serviceAccountKey.json
*.env
.env*

# iOS CocoaPods (regenerated by `pod install`)
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Podfile.lock

# Node deps (regenerated by `npm install`)
functions/node_modules/
functions/.firebase/
functions/firebase-debug.log
functions/*.log

# Firebase emulator state
.firebase/
firebase-debug.log
